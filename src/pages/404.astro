---
import Page from '../layouts/Page.astro';
import SearchBox from '../components/SearchBox.astro';
import { t } from '../lib/i18n';
---

<Page
    title="404"
    description="Sayfa bulunamadı / Page not found"
    lang="tr"
    altLangUrl="/en"
>
    <section class="mb-12 text-center">
        <p class="text-6xl font-semibold tracking-tight">404</p>
        <h1 class="mt-4 text-2xl font-semibold tracking-tight">{t('tr', 'not_found_title')}</h1>
        <p class="mt-2 max-w-prose mx-auto text-[var(--color-ink-soft)]">{t('tr', 'not_found_body')}</p>
        <div class="mt-6 flex justify-center gap-4 text-sm">
            <a href="/" class="underline hover:text-[var(--color-accent)]">{t('tr', 'not_found_home')}</a>
        </div>
    </section>

    <section class="mb-12">
        <h2 class="mb-3 text-sm uppercase tracking-wider text-[var(--color-ink-mute)]">{t('tr', 'search_title')}</h2>
        <SearchBox lang="tr" id="404tr" />
    </section>

    <hr class="my-12 border-[var(--color-rule)]" />

    <section class="mb-12">
        <p class="text-6xl font-semibold tracking-tight">404</p>
        <h2 class="mt-4 text-2xl font-semibold tracking-tight">{t('en', 'not_found_title')}</h2>
        <p class="mt-2 max-w-prose text-[var(--color-ink-soft)]">{t('en', 'not_found_body')}</p>
        <div class="mt-6 flex gap-4 text-sm">
            <a href="/en" class="underline hover:text-[var(--color-accent)]">{t('en', 'not_found_home')}</a>
        </div>
    </section>
</Page>
