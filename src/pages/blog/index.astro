---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';
import { tagSlug } from '../../lib/tags';

const posts = (await getCollection('blog'))
    .filter((p) => !p.data.draft)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const dateFmt = new Intl.DateTimeFormat('tr-TR', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
});
---

<Page title="Blog · notlar.im" description="Buğra Canata'nın blog yazıları">
    <section class="mb-8">
        <h1 class="text-2xl font-semibold tracking-tight">Blog</h1>
        <p class="mt-2 text-[var(--color-ink-soft)]">{posts.length} yazı.</p>
    </section>

    <ul class="divide-y divide-[var(--color-rule)]">
        {
            posts.map((post) => (
                <li class="py-4">
                    <h2 class="text-xl font-semibold leading-snug">
                        <a href={`/blog/${post.id}`} class="hover:underline">
                            {post.data.title}
                        </a>
                    </h2>
                    <div class="mt-1 text-sm text-[var(--color-ink-mute)]">
                        <time datetime={post.data.date.toISOString()}>
                            {dateFmt.format(post.data.date)}
                        </time>
                    </div>
                    {post.data.tags.length > 0 && (
                        <ul class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm text-[var(--color-ink-mute)]">
                            {post.data.tags.map((t) => (
                                <li>
                                    <a
                                        href={`/t/${tagSlug(t)}`}
                                        class="hover:text-[var(--color-ink-soft)] hover:underline"
                                    >
                                        #{t.replace(/\s+/g, '-')}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    )}
                </li>
            ))
        }
    </ul>
</Page>
