---
import Page from '../../layouts/Page.astro';
import AiBadge from '../../components/AiBadge.astro';
import Toc from '../../components/Toc.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import readingTime from 'reading-time';
import { tagSlug } from '../../lib/tags';
import { t } from '../../lib/i18n';
import { relatedPosts, adjacentPosts } from '../../lib/related';
import { blogPosting } from '../../lib/jsonld';

export async function getStaticPaths() {
    const all = await getCollection('blog');
    const trAll = all.filter((p) => p.data.lang === 'tr' && !p.data.draft);
    const sorted = [...trAll].sort(
        (a, b) => b.data.date.getTime() - a.data.date.getTime(),
    );

    return trAll.map((post) => {
        const { newer, older } = adjacentPosts(post, sorted);
        const related = relatedPosts(post, trAll);
        const minutes = Math.max(1, Math.round(readingTime(post.body ?? '').minutes));

        // Resolve EN counterpart by translationKey, if one exists.
        let altLangUrl: string | undefined;
        if (post.data.translationKey) {
            const en = all.find(
                (p) =>
                    p.data.lang === 'en' &&
                    p.data.translationKey === post.data.translationKey,
            );
            altLangUrl = en ? `/en/blog/${en.id}` : '/en';
        }

        return {
            params: { slug: post.id },
            props: { post, newer, older, related, minutes, altLangUrl },
        };
    });
}

interface Props {
    post: CollectionEntry<'blog'>;
    newer: CollectionEntry<'blog'> | null;
    older: CollectionEntry<'blog'> | null;
    related: CollectionEntry<'blog'>[];
    minutes: number;
    altLangUrl?: string;
}
const { post, newer, older, related, minutes, altLangUrl } = Astro.props as Props;
const { Content, headings } = await render(post);
const lang = 'tr' as const;
const postUrl = new URL(`/blog/${post.id}`, Astro.site ?? 'https://notlar.im').toString();
const dateFmt = new Intl.DateTimeFormat(t(lang, 'date_locale'), {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
});
const shortDateFmt = new Intl.DateTimeFormat(t(lang, 'date_locale'), {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
});
---

<Page
    title={post.data.title}
    description={post.data.description ?? post.data.excerpt}
    ogType="article"
    canonical={post.data.canonical}
    lang={lang}
    altLangUrl={altLangUrl}
    ogSlug={post.id}
    schema={blogPosting(post, postUrl)}
>
    <article
        data-pagefind-body
        data-pagefind-filter="lang:tr"
        data-pagefind-meta={`title:${post.data.title}`}
    >
        <header class="mb-8" data-pagefind-ignore>
            <h1 class="text-3xl font-semibold leading-tight tracking-tight">
                {post.data.title}
                {post.data.ai && (
                    <>
                        {' '}
                        <AiBadge label="YZ" title={t(lang, 'meta_ai_long')} />
                    </>
                )}
            </h1>
            <div class="mt-3 flex flex-wrap items-baseline gap-x-3 text-sm text-[var(--color-ink-mute)]">
                <time datetime={post.data.date.toISOString()}>
                    {dateFmt.format(post.data.date)}
                </time>
                <span aria-hidden="true">·</span>
                <span>{t(lang, 'reading_time', { minutes })}</span>
                {post.data.updated && (
                    <>
                        <span aria-hidden="true">·</span>
                        <span>
                            {t(lang, 'meta_updated')} {dateFmt.format(post.data.updated)}
                        </span>
                    </>
                )}
            </div>
            {post.data.tags.length > 0 && (
                <ul class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-sm text-[var(--color-ink-mute)]">
                    {post.data.tags.map((tag) => (
                        <li>
                            <a
                                href={`/t/${tagSlug(tag)}`}
                                class="hover:text-[var(--color-ink-soft)] hover:underline"
                            >
                                #{tag.replace(/\s+/g, '-')}
                            </a>
                        </li>
                    ))}
                </ul>
            )}
        </header>
        <Toc headings={headings} lang={lang} />
        <div class="prose">
            <Content />
        </div>
    </article>

    {(newer || older) && (
        <nav class="mt-16 grid grid-cols-1 gap-4 border-t border-[var(--color-rule)] pt-6 sm:grid-cols-2" aria-label={t(lang, 'related_posts')}>
            {newer ? (
                <a href={`/blog/${newer.id}`} class="group block rounded-md border border-[var(--color-rule)] px-4 py-3 transition hover:border-[var(--color-ink-soft)]">
                    <div class="text-xs uppercase tracking-wider text-[var(--color-ink-mute)]">← {t(lang, 'prev_post')}</div>
                    <div class="mt-1 text-sm font-semibold leading-snug group-hover:text-[var(--color-accent)]">{newer.data.title}</div>
                    <div class="mt-1 text-xs text-[var(--color-ink-mute)]">{shortDateFmt.format(newer.data.date)}</div>
                </a>
            ) : <span />}
            {older ? (
                <a href={`/blog/${older.id}`} class="group block rounded-md border border-[var(--color-rule)] px-4 py-3 text-right transition hover:border-[var(--color-ink-soft)]">
                    <div class="text-xs uppercase tracking-wider text-[var(--color-ink-mute)]">{t(lang, 'next_post')} →</div>
                    <div class="mt-1 text-sm font-semibold leading-snug group-hover:text-[var(--color-accent)]">{older.data.title}</div>
                    <div class="mt-1 text-xs text-[var(--color-ink-mute)]">{shortDateFmt.format(older.data.date)}</div>
                </a>
            ) : <span />}
        </nav>
    )}

    {related.length > 0 && (
        <section class="mt-12">
            <h2 class="text-base font-semibold uppercase tracking-wider text-[var(--color-ink-soft)]">{t(lang, 'related_posts')}</h2>
            <ul class="mt-4 divide-y divide-[var(--color-rule)]">
                {related.map((r) => (
                    <li class="py-3">
                        <a href={`/blog/${r.id}`} class="block hover:text-[var(--color-accent)]">
                            <span class="font-semibold">{r.data.title}</span>
                            <span class="ml-2 text-xs text-[var(--color-ink-mute)]">{shortDateFmt.format(r.data.date)}</span>
                        </a>
                    </li>
                ))}
            </ul>
        </section>
    )}
</Page>
