---
import Page from '../layouts/Page.astro';
import SearchBox from '../components/SearchBox.astro';
import { t } from '../lib/i18n';

const lang = 'tr' as const;
---

<Page title={t(lang, 'search_title')} description="notlar.im içinde ara." lang={lang} altLangUrl="/en/search">
    <section class="mb-8">
        <h1 class="text-2xl font-semibold tracking-tight">{t(lang, 'search_title')}</h1>
        <p class="mt-2 text-sm text-[var(--color-ink-soft)]">{t(lang, 'search_kbd_hint')}</p>
    </section>
    <SearchBox lang={lang} id="page" autofocus eager />
</Page>
