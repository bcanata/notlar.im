---
import Page from '../layouts/Page.astro';
import { getCollection } from 'astro:content';
import { tagSlug } from '../lib/tags';

const blog = (await getCollection('blog')).filter((p) => !p.data.draft);
const notlar = (await getCollection('notlar')).filter((p) => !p.data.draft);

type FeedEntry = {
    collection: 'blog' | 'notlar';
    slug: string;
    title: string;
    date: Date;
    tags: string[];
};

const feed: FeedEntry[] = [
    ...blog.map((p) => ({
        collection: 'blog' as const,
        slug: p.id,
        title: p.data.title,
        date: p.data.date,
        tags: p.data.tags,
    })),
    ...notlar.map((p) => ({
        collection: 'notlar' as const,
        slug: p.id,
        title: p.data.title,
        date: p.data.updated ?? p.data.date,
        tags: p.data.tags,
    })),
].sort((a, b) => b.date.getTime() - a.date.getTime());

const dateFmt = new Intl.DateTimeFormat('tr-TR', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
});
---

<Page
    title="notlar.im"
    description="Buğra Canata — yazılım, telsiz, bisiklet ve dünya üzerine kısa notlar."
>
    <section class="mb-12">
        <h1 class="text-2xl font-semibold tracking-tight">notlar.im</h1>
        <p class="mt-2 text-[var(--color-ink-soft)]">
            Yazılım, amatör telsiz, bisiklet ve karşıma çıkan diğer şeyler üzerine
            kısa notlar. Buğra Canata.
        </p>
    </section>

    <ul class="divide-y divide-[var(--color-rule)]">
        {
            feed.map((entry) => (
                <li class="py-4">
                    <article>
                        <h2 class="text-xl font-semibold leading-snug">
                            <a
                                href={`/${entry.collection}/${entry.slug}`}
                                class="hover:underline"
                            >
                                {entry.title}
                            </a>
                        </h2>
                        <div class="mt-1 flex flex-wrap items-baseline gap-x-2 text-sm text-[var(--color-ink-mute)]">
                            <time datetime={entry.date.toISOString()}>
                                {dateFmt.format(entry.date)}
                            </time>
                            {entry.collection === 'notlar' && (
                                <>
                                    <span aria-hidden="true">·</span>
                                    <span>not</span>
                                </>
                            )}
                        </div>
                        {entry.tags.length > 0 && (
                            <ul class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm text-[var(--color-ink-mute)]">
                                {entry.tags.map((t) => (
                                    <li>
                                        <a
                                            href={`/t/${tagSlug(t)}`}
                                            class="hover:text-[var(--color-ink-soft)] hover:underline"
                                        >
                                            #{t.replace(/\s+/g, '-')}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        )}
                    </article>
                </li>
            ))
        }
    </ul>
</Page>
