---
import Page from '../layouts/Page.astro';
import BookGrid from '../components/BookGrid.astro';
import { allBooks, bookCount } from '../lib/books';
import { t } from '../lib/i18n';

const lang = 'tr' as const;
// Covered books first (visually richer at the top), then the rest by title.
const books = allBooks()
    .slice()
    .sort((a, b) => {
        if (!!a.cover !== !!b.cover) return a.cover ? -1 : 1;
        return a.title.localeCompare(b.title, 'tr');
    });
---

<Page
    title={t(lang, 'books_title')}
    description={t(lang, 'books_tagline')}
    lang={lang}
    altLangUrl="/en/library"
>
    <section class="mb-8">
        <h1 class="display-title text-3xl">{t(lang, 'books_title')}</h1>
        <p class="mt-2 max-w-prose text-[var(--color-ink-soft)]">{t(lang, 'books_tagline')}</p>
    </section>

    <BookGrid
        books={books}
        base="/kitaplik"
        searchPlaceholder={t(lang, 'books_search_placeholder')}
        countLabel={t(lang, 'books_count', { n: '{n}' })}
        noResultsLabel={t(lang, 'books_no_results')}
    />
</Page>
