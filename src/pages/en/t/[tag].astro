---
import Page from '../../../layouts/Page.astro';
import { getCollection } from 'astro:content';
import { tagSlug } from '../../../lib/tags';
import { t } from '../../../lib/i18n';

const PAGE_LANG = 'en' as const;

export async function getStaticPaths() {
    const posts = (await getCollection('blog')).filter((p) => p.data.lang === 'en');
    const byTag = new Map<
        string,
        { displayName: string; entries: typeof posts }
    >();
    for (const post of posts) {
        if (post.data.draft) continue;
        for (const tag of post.data.tags) {
            const slug = tagSlug(tag);
            if (!byTag.has(slug)) byTag.set(slug, { displayName: tag, entries: [] });
            byTag.get(slug)!.entries.push(post);
        }
    }

    return Array.from(byTag.entries()).map(([slug, { displayName, entries }]) => ({
        params: { tag: slug },
        props: {
            displayName,
            entries: entries.sort(
                (a, b) => b.data.date.getTime() - a.data.date.getTime(),
            ),
        },
    }));
}

const { displayName, entries } = Astro.props;
const dateFmt = new Intl.DateTimeFormat(t(PAGE_LANG, 'date_locale'), {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
});
---

<Page
    title={`#${displayName}`}
    description={`Posts tagged ${displayName}`}
    lang={PAGE_LANG}
    altLangUrl="/etiketler"
>
    <section class="mb-8">
        <p class="text-sm uppercase tracking-wider text-[var(--color-ink-mute)]">{t(PAGE_LANG, 'tag_label')}</p>
        <h1 class="mt-1 text-2xl font-semibold tracking-tight">#{displayName}</h1>
        <p class="mt-2 text-sm text-[var(--color-ink-soft)]">{t(PAGE_LANG, 'tag_count', { n: entries.length })}</p>
    </section>

    <ul class="divide-y divide-[var(--color-rule)]">
        {
            entries.map((post) => (
                <li class="py-4">
                    <h2 class="text-lg font-semibold leading-snug">
                        <a href={`/en/blog/${post.id}`} class="hover:underline">
                            {post.data.title}
                        </a>
                    </h2>
                    <div class="mt-1 text-sm text-[var(--color-ink-mute)]">
                        <time datetime={post.data.date.toISOString()}>
                            {dateFmt.format(post.data.date)}
                        </time>
                    </div>
                </li>
            ))
        }
    </ul>
</Page>
