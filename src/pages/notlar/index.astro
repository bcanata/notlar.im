---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';
import { tagSlug } from '../../lib/tags';

const notes = (await getCollection('notlar'))
    .filter((n) => !n.data.draft)
    .sort((a, b) => {
        const da = (a.data.updated ?? a.data.date).getTime();
        const db = (b.data.updated ?? b.data.date).getTime();
        return db - da;
    });

const dateFmt = new Intl.DateTimeFormat('tr-TR', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
});
---

<Page title="Notlar · notlar.im" description="Sürekli güncellenen kişisel notlar">
    <section class="mb-8">
        <h1 class="text-2xl font-semibold tracking-tight">Notlar</h1>
        <p class="mt-2 text-[var(--color-ink-soft)]">
            Bir-iki konuya odaklanan, zaman içinde güncellenen kısa notlar.
        </p>
    </section>

    <ul class="divide-y divide-[var(--color-rule)]">
        {
            notes.map((note) => (
                <li class="py-4">
                    <h2 class="text-xl font-semibold leading-snug">
                        <a href={`/notlar/${note.id}`} class="hover:underline">
                            {note.data.title}
                        </a>
                    </h2>
                    <div class="mt-1 text-sm text-[var(--color-ink-mute)]">
                        <time
                            datetime={(note.data.updated ?? note.data.date).toISOString()}
                        >
                            {dateFmt.format(note.data.updated ?? note.data.date)}
                        </time>
                    </div>
                    {note.data.tags.length > 0 && (
                        <ul class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm text-[var(--color-ink-mute)]">
                            {note.data.tags.map((t) => (
                                <li>
                                    <a
                                        href={`/t/${tagSlug(t)}`}
                                        class="hover:text-[var(--color-ink-soft)] hover:underline"
                                    >
                                        #{t.replace(/\s+/g, '-')}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    )}
                </li>
            ))
        }
    </ul>
</Page>
