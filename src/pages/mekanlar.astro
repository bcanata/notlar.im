---
import Page from '../layouts/Page.astro';
import ReviewsMap from '../components/ReviewsMap.astro';
import ReviewList from '../components/ReviewList.astro';
import { allReviews, mappableReviews } from '../lib/reviews';
import { t } from '../lib/i18n';

const lang = 'tr' as const;
const reviews = allReviews();
const mappable = mappableReviews();
---

<Page
    title={t(lang, 'reviews_title')}
    description={t(lang, 'reviews_tagline')}
    lang={lang}
    altLangUrl="/en/places"
>
    <section class="mb-8">
        <h1 class="display-title text-3xl">{t(lang, 'reviews_title')}</h1>
        <p class="mt-2 max-w-prose text-[var(--color-ink-soft)]">{t(lang, 'reviews_tagline')}</p>
    </section>

    <section class="mb-10">
        <ReviewsMap reviews={mappable} emptyLabel={t(lang, 'reviews_map_empty')} />
    </section>

    <ReviewList
        reviews={reviews}
        lang={lang}
        searchPlaceholder={t(lang, 'reviews_search_placeholder')}
        countLabel={t(lang, 'reviews_count', { n: '{n}' })}
        noResultsLabel={t(lang, 'reviews_no_results')}
        mapLabel={t(lang, 'reviews_map_label')}
        viewLabel={t(lang, 'reviews_view')}
    />
</Page>
