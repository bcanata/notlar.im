{
  "name": "notlar.im",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "pnpm run build && wrangler deploy",
    "deploy:dry": "pnpm run build && wrangler deploy --dry-run",
    "refresh-yt": "node scripts/refresh-youtube.mjs",
    "enrich-books": "node scripts/enrich-books.mjs",
    "import-reviews": "node scripts/import-reviews.mjs",
    "export-books-sql": "node scripts/export-books-sql.mjs",
    "upload-covers-r2": "node scripts/upload-covers-r2.mjs",
    "db:schema:local": "wrangler d1 execute notlar-library --local --file=db/schema.sql",
    "db:schema:remote": "wrangler d1 execute notlar-library --remote --file=db/schema.sql",
    "db:seed:local": "wrangler d1 execute notlar-library --local --file=db/seed.sql",
    "db:seed:remote": "wrangler d1 execute notlar-library --remote --file=db/seed.sql",
    "db:migrate:local": "wrangler d1 execute notlar-library --local --file=db/migrations/0002_home_library.sql",
    "db:migrate:remote": "wrangler d1 execute notlar-library --remote --file=db/migrations/0002_home_library.sql",
    "db:copies:remote": "wrangler d1 execute notlar-library --remote --file=db/migrations/0003_copies.sql"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/mdx": "^4.3.6",
    "@astrojs/rss": "^4.0.13",
    "@astrojs/sitemap": "^3.6.0",
    "@tailwindcss/vite": "^4.1.12",
    "@zxing/browser": "^0.2.0",
    "@zxing/library": "^0.22.0",
    "astro": "^5.16.4",
    "astro-og-canvas": "^0.11.1",
    "canvaskit-wasm": "^0.41.1",
    "gray-matter": "^4.0.3",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "pagefind": "^1.5.2",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "vite": "^6.4.1",
    "wrangler": "^4.94.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "^6.4.1"
    }
  }
}
